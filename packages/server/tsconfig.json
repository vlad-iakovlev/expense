{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "rootDir": "src",
    "target": "esnext",
    "types": ["node"]
  },
  "exclude": ["node_modules"],
  "include": ["src"]
}
