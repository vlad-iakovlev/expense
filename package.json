{
  "name": "expense",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:client": "npm run build --workspace @expense/client",
    "compile:client": "npm run compile --workspace @expense/client",
    "compile:server": "npm run compile --workspace @expense/server",
    "dev:client": "npm run dev --workspace @expense/client",
    "dev:server": "npm run dev --workspace @expense/server",
    "generate:currencies": "npm run generate-currencies --workspace @expense/generators",
    "generate:icons": "npm run generate-icons --workspace @expense/generators",
    "generate:splashes": "npm run generate-splashes --workspace @expense/generators",
    "lint": "eslint .",
    "lint:ci": "DEBUG=eslint:eslint eslint .",
    "prettier": "prettier --write '**/*.(js|ts|tsx|md|json)'",
    "prettier:ci": "prettier --check '**/*.(js|ts|tsx|md|json)'",
    "prisma": "npm run prisma --workspace @expense/db --",
    "prisma:env": "dotenv -e .env -- npm run prisma --",
    "start:client": "npm run preview --workspace @expense/client",
    "start:server": "npm run start --workspace @expense/server"
  },
  "dependencies": {
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@serwist/next": "^9.5.7",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vlad-iakovlev/eslint-config": "^1.2.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "serwist": "^9.5.6",
    "typescript": "^5.9.3"
  }
}
