{
  "name": "expense",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "next build --webpack",
    "build:client": "npm run build --workspace @expense/client",
    "compile": "tsc",
    "compile:client": "npm run compile --workspace @expense/client",
    "compile:server": "npm run compile --workspace @expense/server",
    "dev": "next dev --webpack",
    "dev:client": "npm run dev --workspace @expense/client",
    "dev:server": "npm run dev --workspace @expense/server",
    "generate-currencies": "node --loader ts-node/esm bin/generate-currencies.mts",
    "generate-icons": "node --loader ts-node/esm bin/generate-icons.mts",
    "generate-splashes": "node --loader ts-node/esm bin/generate-splashes.mts",
    "lint": "eslint .",
    "lint:ci": "DEBUG=eslint:eslint eslint .",
    "prettier": "prettier --write '**/*.(js|ts|tsx|md|json)'",
    "prettier:ci": "prettier --check '**/*.(js|ts|tsx|md|json)'",
    "prisma": "dotenv -e .env -- npx prisma",
    "start": "next start",
    "start:client": "npm run preview --workspace @expense/client",
    "start:server": "npm run start --workspace @expense/server"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@serwist/next": "^9.5.7",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vlad-iakovlev/eslint-config": "^1.2.0",
    "chalk": "^5.6.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "fast-xml-parser": "^5.5.9",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.6.0",
    "serwist": "^9.5.6",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
