{
  "name": "expense",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:client": "npm run build --workspace @expense/client",
    "compile": "tsc && npm run compile --workspaces --if-present",
    "dev:client": "npm run dev --workspace @expense/client",
    "dev:server": "npm run dev --workspace @expense/server",
    "generate-currencies": "npm run generate-currencies --workspace @expense/generators",
    "generate-icons": "npm run generate-icons --workspace @expense/generators",
    "generate-splashes": "npm run generate-splashes --workspace @expense/generators",
    "lint": "eslint .",
    "lint:ci": "DEBUG=eslint:eslint eslint .",
    "prettier": "prettier --write '**/*.(js|mjs|ts|mts|tsx|md|json)'",
    "prettier:ci": "prettier --check '**/*.(js|mjs|ts|mts|tsx|md|json)'",
    "prisma": "npm run prisma --workspace @expense/prisma --",
    "start:client": "npm run preview --workspace @expense/client",
    "start:server": "npm run start --workspace @expense/server"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vlad-iakovlev/eslint-config": "^1.2.0",
    "eslint": "^9.39.4",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3"
  }
}
